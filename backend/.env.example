# Bursa Insight backend config (copy to .env). All optional — sane defaults apply.
BURSA_CORS_ORIGINS=*
BURSA_DEFAULT_LOOKBACK=1y
BURSA_GUEST_INDICES=KLCI

# --- auth (gates GEX / Market Index / R-Appetite) ---
# REQUIRED IN PRODUCTION: strong random secret used to sign session JWTs.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# If left unset, an insecure PUBLIC dev default is used and anyone can forge a session.
# (Uncomment and fill — leaving it blank would set an EMPTY secret, which is worse.)
#BURSA_JWT_SECRET=replace-with-a-long-random-string
# Google OAuth Web Client ID; incoming Google ID tokens must carry this audience.
# Must match the frontend <meta name="google-client-id"> and your Google Cloud
# "Authorized JavaScript origins". Defaults to the ID committed in index.html.
#BURSA_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# Session lifetime in hours (default 168 = 7 days).
#BURSA_JWT_TTL_HOURS=168

# --- outbound email (account-confirmation links) ---
# If these are blank, the app runs in DEV MODE: the confirmation link is printed
# to the server console instead of emailed (fine for local testing). To actually
# send email via Gmail: turn on 2-Step Verification on the Google account, create
# an "App password" (Google Account → Security → App passwords), and put it below.
#BURSA_SMTP_HOST=smtp.gmail.com
#BURSA_SMTP_PORT=587
#BURSA_SMTP_USER=youraddress@gmail.com
#BURSA_SMTP_PASSWORD=your-16-char-app-password
#BURSA_SMTP_FROM=youraddress@gmail.com
# Public base URL used to build the confirmation link (else derived from the
# request). Set on the live site, e.g. https://bursa-insight.onrender.com
#BURSA_PUBLIC_URL=
